# 공개 사이트 URL (끝 슬래시 없음). OG·sitemap·robots·admin 동기화 트리거에 사용됩니다.
NEXT_PUBLIC_SITE_URL=https://fireplc.com

# Kakao Local REST (서버 전용) — 검색·역지오코딩(좌표→주소) 등
# KAKAO_REST_API_KEY=

# 동기화 API 보호(선택). 설정 시 x-sync-secret 헤더가 일치하거나 ALLOW_ANONYMOUS_SYNC=true 여야 브라우저에서 동기화 가능
# SYNC_PLACES_SECRET=
# ALLOW_ANONYMOUS_SYNC=

# 문의 이메일 (개인정보처리방침·문의 페이지에 표시)
NEXT_PUBLIC_CONTACT_EMAIL=

# Google AdSense (콘솔의 ca-pub-… ID). Vercel에 추가 후 반드시 재배포 (빌드 시 HTML에 박힘).
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=

# Naver Maps JS SDK (프론트엔드 지도 표시용)
# Naver Maps는 Client Secret이 아니라 Client ID만 사용합니다.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# AdSense/Search Console 사이트 확인용 메타 태그 값 (콘솔에서 복사한 content만)
GOOGLE_SITE_VERIFICATION=
